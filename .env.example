# =========================================================

# --- 1. Database (SMHRD 외부 서버 접속 정보) ---
# [주의] 이안 팀장님이 구축한 외부 서버 호스트와 포트입니다.
DB_HOST=project-db-campus.smhrd.com
DB_PORT=3307
DB_NAME=campus_25IS_DCX1_p3_2
DB_USER=campus_25IS_DCX1_p3_2
DB_PASSWORD=smhrd2

# --- 2. HyperCLOVA X (AI 상담 헬퍼 연동) ---
# [참고] 팀장님이 공유해주신 API 키를 입력하세요.
HCX_HOST=https://clovastudio.stream.ntruss.com
HCX_API_KEY=Bearer nv-3c3ceaf4991e4b5f8d72426778ab35ceQZcj
HCX_MODEL=HCX-DASH-002
USE_HCX=1

# --- 3. Frontend / Backend API Address ---
# [주의] 본인 로컬에서 FastAPI 실행 시 아래 주소를 유지하세요.
